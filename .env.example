# Copy this file to .env and replace every placeholder value.
# Never commit the real .env file.

DJANGO_DEBUG=True
DJANGO_SECRET_KEY=replace-with-a-long-random-secret-key
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

DB_ENGINE=django.db.backends.postgresql
DB_NAME=Liquor_ERP_POS
DB_USER=postgres
DB_PASSWORD=replace-with-your-database-password
DB_HOST=localhost
DB_PORT=5432

# Leave blank to use DJANGO_SECRET_KEY for JWT signing.
JWT_SIGNING_KEY=
JWT_ACCESS_TOKEN_MINUTES=60
JWT_REFRESH_TOKEN_DAYS=7
JWT_SLIDING_TOKEN_MINUTES=60
JWT_SLIDING_REFRESH_DAYS=7

# For local frontend development only. In production, set this to False
# and list exact origins in CORS_ALLOWED_ORIGINS.
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5172,http://127.0.0.1:5172
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5172,http://127.0.0.1:5172

SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
SECURE_PROXY_SSL_HEADER=False
